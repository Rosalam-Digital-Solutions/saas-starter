# Required: app base URL used for redirects and callbacks.
BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required: Postgres connection string used by Drizzle and the app.
POSTGRES_URL=postgresql://user:password@localhost:54322/postgres

# Required: auth/session secret. Keep server-only.
AUTH_SECRET=replace-with-random-secret

# Required: Gebar server key. Keep server-only.
GEBARBILLING_SECRET_KEY=

# Required: Gebar API base URL. Keep server-only.
GEBARBILLING_BASE_URL=https://api.gebarbilling.et

# Required: Gebar webhook secret. Keep server-only.
GEBARBILLING_WEBHOOK_SECRET=

# Required: Gebar plan IDs. Keep server-only.
GEBARBILLING_BASE_PLAN_ID=
GEBARBILLING_PLUS_PLAN_ID=

# Optional: monthly price metadata for display or local testing.
GEBARBILLING_BASE_PRICE_MONTHLY=800
GEBARBILLING_PLUS_PRICE_MONTHLY=1200

# Optional: billing currency code.
GEBARBILLING_CURRENCY=usd

# Browser-safe hosted Gebar billing URL validation.
# Comma-separated list of allowed domains for URL validation.
NEXT_PUBLIC_GEBAR_CHECKOUT_DOMAIN=https://checkout.gebarbilling.et

# Environment passed through to the Gebar SDK and hosted checkout URL.
GEBARBILLING_ENV=development
