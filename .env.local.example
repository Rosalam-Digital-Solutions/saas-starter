# Required: local app URL used by Next.js and billing redirects.
BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required: local Postgres connection string.
POSTGRES_URL=postgresql://user:password@localhost:54322/postgres

# Required: random secret used for local auth/session work.
AUTH_SECRET=replace-with-random-secret

# Required: Gebar server credentials. Keep these out of client code.
GEBARBILLING_SECRET_KEY=
GEBARBILLING_BASE_URL=https://api.gebarbilling.et
GEBARBILLING_WEBHOOK_SECRET=

# Required: local plan identifiers from your Gebar workspace.
GEBARBILLING_BASE_PLAN_ID=
GEBARBILLING_PLUS_PLAN_ID=

# Optional: local pricing metadata.
GEBARBILLING_BASE_PRICE_MONTHLY=800
GEBARBILLING_PLUS_PRICE_MONTHLY=1200
GEBARBILLING_CURRENCY=usd

# Browser-safe hosted Gebar billing URL validation.
# Comma-separated list of allowed domains for URL validation.
NEXT_PUBLIC_GEBAR_CHECKOUT_DOMAIN=https://checkout.gebarbilling.et

# Environment used in hosted checkout URLs (prod, staging, sandbox).
GEBARBILLING_ENV=prod
